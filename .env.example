# ---- opentdm configuration (copy to .env) ----

# REQUIRED. Base64-encoded 32-byte master encryption key.
# Generate: openssl rand -base64 32
# WARNING: losing this makes all encrypted data unrecoverable. Back it up out-of-band.
OPENTDM_MASTER_KEY=

# REQUIRED. Pepper for hashing service/session tokens (kept out of the DB).
# Generate: openssl rand -base64 32
OPENTDM_TOKEN_PEPPER=

# REQUIRED. Secret used to sign/derive session material.
# Generate: openssl rand -base64 32
OPENTDM_SESSION_SECRET=

# Database connection (the docker-compose default points at the bundled postgres service).
DATABASE_URL=postgres://opentdm:opentdm@postgres:5432/opentdm?sslmode=disable

# ---- Server (all optional; defaults shown) ----
OPENTDM_BIND=0.0.0.0
PORT=8080
# Externally-visible base URL. Used to build invitation accept links — set this to
# your real URL (e.g. https://opentdm.example.com) in production.
OPENTDM_HOST=http://localhost:8080
OPENTDM_LOG_LEVEL=info
OPENTDM_LOG_FORMAT=json
OPENTDM_MIGRATE_ON_START=true
OPENTDM_MAX_BLOB_BYTES=10485760

# Per-IP rate limiting for the unauthenticated auth endpoints (login, bootstrap,
# invitation accept). Set RPM to 0 to disable (e.g. if a reverse proxy limits).
OPENTDM_AUTH_RATELIMIT_RPM=10
OPENTDM_AUTH_RATELIMIT_BURST=5

# Optional: serve the web UI from disk instead of the embedded build (dev convenience).
# OPENTDM_WEB_DIR=

# ---- SMTP for invitation emails (all optional) ----
# If OPENTDM_SMTP_HOST/OPENTDM_SMTP_FROM are unset, invitations still work but the
# accept link is written to the server logs (and returned to the inviter) instead
# of being emailed.
# OPENTDM_SMTP_HOST=smtp.example.com
# OPENTDM_SMTP_PORT=587
# OPENTDM_SMTP_USERNAME=
# OPENTDM_SMTP_PASSWORD=
# OPENTDM_SMTP_FROM=opentdm@example.com
# OPENTDM_SMTP_TLS=starttls   # starttls | implicit | none

# ---- docker-compose only ----
POSTGRES_PASSWORD=opentdm
OPENTDM_PORT=8080
